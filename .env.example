# PIX estático — QR gerado no browser (sem Mercado Pago)
# Chave: e-mail | CPF/CNPJ só números | telefone DDD+número | chave aleatória UUID
# Nome: EXATAMENTE como cadastrado no banco na chave PIX (até 25 caracteres, sem acento)
# Cidade: até 15 caracteres no padrão PIX (ex.: BELEM). Reinicie npm run dev após alterar.
VITE_PIX_KEY=
VITE_PIX_MERCHANT_NAME=
VITE_PIX_MERCHANT_CITY=

# Supabase (opcional — catálogo, RSVP e registro manual de pagamentos no admin)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
